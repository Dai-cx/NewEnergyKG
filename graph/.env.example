# 新能源知识图谱构建与评估模块环境变量示例
# 复制本文件为 .env 并填写真实 Neo4j 密码后即可运行 graph/ 下的脚本

# ==================== Neo4j 知识图谱配置 ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ==================== 数据文件路径（可选）====================
# 默认使用项目根目录下的 data/new_energy.json
# 如需使用其他数据文件，取消下面注释并修改路径
# GRAPH_DATA_PATH=../data/new_energy.json

# ==================== 调试开关（可选）====================
# GRAPH_DEBUG=false
