# 新能源知识图谱项目环境变量示例
# 复制本文件为 .env 并填写真实配置后，项目各模块均可读取。
#
# 加载规则：
#   - qa/config.py 会自动加载 qa/.env
#   - graph/config.py 会自动加载项目根目录 .env 和 graph/.env
#   - data/generate_mock_data.py 会读取环境变量 NEO4J_PASSWORD
# 建议：将本文件复制为项目根目录 .env，并在 qa/ 和 graph/ 下创建符号链接或再复制一份。

# ==================== Neo4j 知识图谱配置（必需）====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ==================== 数据文件路径（可选）====================
# graph/build_newenergy_graph.py 默认使用项目根目录 data/new_energy.json
# 如需使用其他数据文件，取消下面注释并修改路径（相对路径以 graph/ 目录为基准）
# GRAPH_DATA_PATH=../data/new_energy.json

# ==================== DashScope（通义千问，默认）====================
# 访问 https://dashscope.aliyun.com/ 获取 API Key
DASHSCOPE_API_KEY=your-dashscope-api-key-here
LLM_MODEL=qwen-turbo

# ==================== OpenAI 兼容接口（可选）====================
# OPENAI_API_BASE=https://your-api-base.com/v1
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# ==================== LLM 参数（可选）====================
# LLM_TIMEOUT=30
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.3

# ==================== 服务参数（可选）====================
# APP_HOST=127.0.0.1
# APP_PORT=8000

# ==================== 实体识别配置（可选）====================
# rapidfuzz 模糊匹配阈值（0-100），默认 85；提高可减少误召回，降低可增加召回
# ENTITY_FUZZY_THRESHOLD=85

# ==================== 调试开关（可选）====================
# QA_DEBUG=false
# GRAPH_DEBUG=false
