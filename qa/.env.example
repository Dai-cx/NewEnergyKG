# 新能源知识图谱问答系统环境变量示例
# 复制本文件为 .env 并填写真实 API Key / Neo4j 密码后即可启用完整功能

# ==================== Neo4j 知识图谱配置（可选）====================
# 若本地已启动 Neo4j，取消下面注释并填写真实密码，即可启用 KG+RAG
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-neo4j-password

# ==================== DashScope（通义千问，默认）====================
# 访问 https://dashscope.aliyun.com/ 获取 API Key
DASHSCOPE_API_KEY=your-dashscope-api-key-here
LLM_MODEL=qwen-turbo

# ==================== OpenAI 兼容接口（可选）====================
# 若使用本地模型或其他厂商 OpenAI 兼容接口，取消下面注释并填写
# OPENAI_API_BASE=https://your-api-base.com/v1
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# ==================== LLM 参数（可选）====================
# LLM_TIMEOUT=30
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.3

# ==================== 服务参数（可选）====================
# APP_HOST=127.0.0.1
# APP_PORT=8000

# ==================== 实体识别配置（可选）====================
# rapidfuzz 模糊匹配阈值（0-100），默认 85；提高可减少误召回，降低可增加召回
# ENTITY_FUZZY_THRESHOLD=85

# ==================== 调试开关（可选）====================
# QA_DEBUG=false
